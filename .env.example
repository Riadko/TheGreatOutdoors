# Copy this file to .env and set your own values
# Frontend endpoint to submit orders (defaults to /.netlify/functions/order-notify)
VITE_ORDER_API_URL=""

# Netlify Function variables (set these in Netlify dashboard, not in frontend)
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
# TWILIO_WHATSAPP_TO="whatsapp:+213XXXXXXXXX"
